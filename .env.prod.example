# FTP Simulator — environnement de production
# Copier vers .env.prod et adapter avant de déployer
# (ne jamais committer .env.prod — il est dans .gitignore)

DATABASE_URL=postgresql://ftp:CHANGE_ME@127.0.0.1:5432/ftp_simulator
LISTEN_ADDR=127.0.0.1:3000
RUST_LOG=warn

# URL du serveur FTP de l'organisation
FTP_SOURCE_URL=ftp://ftp.monorganisation.com/ftp-simulator
